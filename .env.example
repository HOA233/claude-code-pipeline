# ===========================================
# Claude Pipeline Environment Configuration
# ===========================================

# Required: Anthropic API Key
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Required: GitLab Token (for skill sync)
GITLAB_TOKEN=glpat-your-token-here

# ===========================================
# Server Configuration
# ===========================================

# Server port (default: 8080)
SERVER_PORT=8080

# Gin mode: debug, release, test
GIN_MODE=debug

# ===========================================
# Redis Configuration
# ===========================================

# Redis address (default: localhost:6379)
REDIS_ADDR=localhost:6379

# Redis password (optional)
REDIS_PASSWORD=

# Redis database number (default: 0)
REDIS_DB=0

# ===========================================
# GitLab Configuration
# ===========================================

# GitLab URL (default: https://gitlab.com)
GITLAB_URL=https://gitlab.com

# GitLab skills repository path (namespace/project)
GITLAB_SKILLS_REPO=company/claude-skills

# ===========================================
# CLI Executor Configuration
# ===========================================

# Maximum concurrent CLI processes
CLI_MAX_CONCURRENCY=5

# Default timeout for tasks (seconds)
CLI_DEFAULT_TIMEOUT=600

# Path to claude CLI binary (default: claude)
CLI_CLAUDE_PATH=claude

# ===========================================
# Authentication
# ===========================================

# API keys (comma-separated)
API_KEYS=api-key-1,api-key-2

# JWT secret for Bearer tokens
JWT_SECRET=your-jwt-secret-here

# ===========================================
# Rate Limiting
# ===========================================

# Requests per minute per API key
RATE_LIMIT_REQUESTS=100

# Rate limit window (seconds)
RATE_LIMIT_WINDOW=60

# ===========================================
# Logging
# ===========================================

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Log format: json, text
LOG_FORMAT=json

# ===========================================
# Webhooks & Notifications
# ===========================================

# Default webhook URL for task completion
DEFAULT_WEBHOOK_URL=

# Slack webhook URL
SLACK_WEBHOOK_URL=

# Slack channel for notifications
SLACK_CHANNEL=#notifications

# ===========================================
# Metrics & Monitoring
# ===========================================

# Enable Prometheus metrics
ENABLE_METRICS=true

# Metrics port (default: 9090)
METRICS_PORT=9090

# ===========================================
# Storage
# ===========================================

# Task retention period (hours)
TASK_RETENTION_HOURS=24

# Enable task archiving
ENABLE_ARCHIVING=true

# ===========================================
# Development
# ===========================================

# Enable CORS (for development)
ENABLE_CORS=true

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Enable debug endpoints
ENABLE_DEBUG_ENDPOINTS=true